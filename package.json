{
  "name": "wilford-industries",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:website": "npm run dev --workspace @wilford/website",
    "dev:panel": "npm run dev --workspace @wilford/panel",
    "dev:api": "npm run dev --workspace @wilford/api",
    "dev:bot": "npm run dev --workspace @wilford/discord-bot",
    "dev:praetor-bot": "npm run dev --workspace @wilford/praetor-bot",
    "build": "npm run build --workspaces --if-present",
    "start:website": "npm run start --workspace @wilford/website",
    "start:panel": "npm run start --workspace @wilford/panel",
    "start:api": "npm run start --workspace @wilford/api",
    "start:bot": "npm run start --workspace @wilford/discord-bot",
    "start:praetor-bot": "npm run start --workspace @wilford/praetor-bot",
    "lint": "npm run lint --workspaces --if-present",
    "remote:help": "node scripts/remote-deploy.mjs help",
    "remote:shell": "node scripts/remote-deploy.mjs shell",
    "remote:panel": "node scripts/remote-deploy.mjs panel",
    "remote:panel:full": "node scripts/remote-deploy.mjs panel-full",
    "remote:all": "node scripts/remote-deploy.mjs all",
    "remote:services": "node scripts/remote-deploy.mjs services"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.15"
  }
}
